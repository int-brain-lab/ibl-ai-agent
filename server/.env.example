# Copy to .env (local dev) or install as /etc/ibl-feedback.env (systemd
# EnvironmentFile) and fill in. Never commit the filled-in file.

# Django signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
IBL_FEEDBACK_SECRET_KEY=change-me

# 0 in production, 1 only for local debugging.
IBL_FEEDBACK_DEBUG=0

# Comma-separated hostnames this server answers on.
IBL_FEEDBACK_ALLOWED_HOSTS=feedback.example.org

# Comma-separated https origins for CSRF (your public URL).
IBL_FEEDBACK_CSRF_TRUSTED_ORIGINS=https://feedback.example.org

# Shared, write-only token clients present to POST feedback. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# This must match the client's IBL_AGENT_FEEDBACK_TOKEN.
IBL_FEEDBACK_INGEST_TOKEN=change-me

# Optional: absolute path for the SQLite database file.
# Defaults to server/db.sqlite3 next to manage.py.
IBL_FEEDBACK_DB_PATH=/var/lib/ibl-feedback/db.sqlite3
